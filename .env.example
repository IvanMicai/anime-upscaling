# Host directory that contains input/output media.
# The container sees this directory mounted at PROCESS_DIR.
HOST_PROCESS_DIR=./data
PROCESS_DIR=/data

# Ports
API_PORT=4751
APP_PORT=4750

# Web app authentication.
# Replace both values before exposing the app outside a trusted local network.
AUTH_PASSWORD=change-me
AUTH_SECRET=change-me-generate-with-openssl-rand-hex-32

# API URL used by the Next.js app inside Docker Compose.
API_URL=http://api:4751

# Worker concurrency.
GPU_COUNT=1
STREAMS_PER_GPU=1
FFMPEG_STREAMS=1

# Optional hardware encoder for optimize jobs: nvidia, amd, intel, or empty.
GPU_VENDOR=
